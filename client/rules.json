[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "redirect",
      "redirect": {
        "regexSubstitution": "chrome-extension://__extension_id__/index.html?url=\\0"
      }
    },
    "condition": {
      "regexFilter": "^https?://.*",
      "resourceTypes": ["main_frame", "sub_frame"],
      "excludedInitiatorDomains": ["__extension_id__"]
    }
  }
]
