{
  "manifest_version": 3,
  "name": "Wison-RBI",
  "version": "1.6.0",
  "description": "Compositor-layer browser isolation client",
  "author": "Wison-RBI Design Team",
  "homepage_url": "https://github.com/laolv2023/wison-rbi",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src wss://*:*"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "index.js",
        "protocol.js",
        "command_validator.js",
        "utils.js",
        "font_registry.js",
        "image_cache.js",
        "node_modules/canvaskit-wasm/bin/*",
        "node_modules/socket.io-client/dist/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rbi_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
